{
  "expo": {
    "name": "Crave Kitchen",
    "slug": "crave-kitchen",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FF6B35"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.cravekitchen.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "This app uses the camera to take photos of menu items and scan QR codes.",
        "NSPhotoLibraryUsageDescription": "This app accesses your photo library to select images for menu items.",
        "NSLocationWhenInUseUsageDescription": "This app uses location to provide delivery services and show nearby orders.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "This app uses location to provide delivery services and show nearby orders.",
        "NSMicrophoneUsageDescription": "This app uses the microphone for voice notes and audio features.",
        "NSFaceIDUsageDescription": "This app uses Face ID for secure authentication.",
        "UIBackgroundModes": [
          "location",
          "fetch",
          "remote-notification"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FF6B35"
      },
      "package": "com.cravekitchen.app",
      "versionCode": 1,
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "WAKE_LOCK",
        "INTERNET",
        "ACCESS_NETWORK_STATE",
        "RECORD_AUDIO",
        "MODIFY_AUDIO_SETTINGS",
        "BLUETOOTH",
        "BLUETOOTH_ADMIN",
        "NFC",
        "USE_FINGERPRINT",
        "USE_BIOMETRIC"
      ],
      "allowBackup": true,
      "usesCleartextTraffic": false
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-camera",
      "expo-image-picker",
      "expo-notifications",
      "expo-location",
      "expo-secure-store",
      "expo-av",
      "expo-barcode-scanner",
      "expo-print",
      "expo-sharing",
      "expo-media-library",
      "expo-document-picker",
      "expo-image-manipulator",
      "expo-blur",
      "expo-haptics",
      "expo-brightness",
      "expo-battery",
      "expo-network",
      "expo-application",
      "expo-updates"
    ],
    "notification": {
      "icon": "./assets/notification-icon.png",
      "color": "#FF6B35",
      "iosDisplayInForeground": true,
      "androidMode": "default",
      "androidCollapsedTitle": "New Order"
    },
    "updates": {
      "enabled": true,
      "fallbackToCacheTimeout": 0
    },
    "extra": {
      "eas": {
        "projectId": "your-project-id-here"
      },
      "apiUrl": "https://api.cravekitchen.com/v1",
      "environment": "production"
    }
  }
} 